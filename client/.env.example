# Arsi Aseko Platform - Frontend Environment Variables
# Create files: .env.development and .env.production from this template

# ===== Development Configuration (.env.development) =====
VITE_API_BASE_URL=http://localhost:5001/api
VITE_SOCKET_URL=http://localhost:5001
VITE_ENV=development

# ===== Production Configuration (.env.production) =====
# VITE_API_BASE_URL=https://your-backend-api.com/api
# VITE_SOCKET_URL=https://your-backend-api.com
# VITE_ENV=production

# ===== Application Metadata =====
VITE_APP_NAME=Arsi Aseko Platform
VITE_APP_DESCRIPTION=Connect, grow, and succeed together. A community platform for Arsi Aseko students.
VITE_APP_URL=https://yourdomain.com

# ===== Analytics =====
# Google Analytics
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Sentry (Error Tracking)
# VITE_SENTRY_DSN=https://your-sentry-key@sentry.io/your-project-id
# VITE_SENTRY_ENVIRONMENT=production
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# ===== Feature Flags =====
VITE_ENABLE_CHAT=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_FILE_UPLOAD=true
VITE_ENABLE_SOCIAL_FEATURES=true

# ===== UI Configuration =====
VITE_TOAST_DURATION=3000  # milliseconds
VITE_DEBUG_MODE=false  # Set to true for console debugging

# ===== API Configuration =====
VITE_API_TIMEOUT=10000  # milliseconds
VITE_API_RETRY_ATTEMPTS=3
VITE_API_RETRY_DELAY=1000  # milliseconds

# ===== Image Upload =====
VITE_MAX_IMAGE_SIZE=52428800  # 50MB in bytes
VITE_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp

# ===== Performance =====
# Service Worker (PWA)
# VITE_ENABLE_SW=true

# ===== Security =====
# CSP Headers (Content Security Policy)
# Configured in vite.config.js or web server

# ===== Build Output =====
# Set by Vite automatically, but can be customized
# VITE_BUILD_OUTPUT_DIR=dist
# VITE_BUILD_SOURCE_MAP=false  # Disable for production
