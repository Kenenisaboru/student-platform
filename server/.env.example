# Arsi Aseko Platform - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control

# ===== Server Configuration =====
NODE_ENV=development
PORT=5001

# ===== Database =====
# MongoDB Connection String (from MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/arsiaseko?retryWrites=true&w=majority

# ===== Authentication =====
# Generate a random string of at least 32 characters for JWT_SECRET
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_min_32_characters

# ===== CORS Configuration =====
# For development: http://localhost:5173
# For production: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN=http://localhost:5173

# ===== Image Upload (Cloudinary) =====
# Get from: https://cloudinary.com/console
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_KEY=your_cloudinary_api_key
CLOUDINARY_SECRET=your_cloudinary_api_secret

# ===== Email Service (Nodemailer) =====
# Using Gmail: Enable 2FA and generate App Password
# Get App Password: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# Or use SendGrid:
# SENDGRID_API_KEY=your_sendgrid_key

# ===== Socket.io Configuration =====
SOCKET_CORS=http://localhost:5173

# ===== Optional: Redis (for caching/sessions) =====
# REDIS_URL=redis://username:password@localhost:6379

# ===== Optional: Error Tracking (Sentry) =====
# Get from: https://sentry.io
# SENTRY_DSN=https://your-sentry-key@sentry.io/your-project-id

# ===== Optional: Analytics =====
# GOOGLE_ANALYTICS_ID=your_ga_id

# ===== Admin Configuration =====
# Admin email for notifications
ADMIN_EMAIL=admin@arsiaseko.edu.et

# ===== File Upload Limits =====
MAX_FILE_SIZE=52428800  # 50MB in bytes
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# ===== Rate Limiting =====
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=1000  # per window

# ===== Logging =====
LOG_LEVEL=info  # debug, info, warn, error

# ===== Session Configuration =====
SESSION_SECRET=your_session_secret_min_32_characters

# ===== HTTPS =====
# For production only
# HTTPS_ENABLED=true
# SSL_KEY_PATH=/path/to/key.pem
# SSL_CERT_PATH=/path/to/cert.pem

# ===== Feature Flags =====
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=false  # Set to true in production
ENABLE_SOCIAL_LOGIN=false  # For future OAuth integration

# ===== AWS Configuration (Optional) =====
# For S3 file storage, AWS CloudWatch, etc.
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name
